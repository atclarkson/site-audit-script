{
  "name": "site-audit-script",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "npm run build --silent && node dist/src/cli.js",
    "test": "npm run build --silent && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "csv-stringify": "^6.5.1",
    "fast-xml-parser": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "typescript": "^5.9.2"
  }
}
